{
  "publisher": "yuang",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuang-w/vs-ext"
  },
  "name": "vs-ext-yuang",
  "displayName": "yuang's extensions",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyLineRef.copy",
        "title": "Copy Line Reference"
      }
    ],
    "keybindings": [
      {
        "command": "copyLineRef.copy",
        "key": "alt+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.0"
  }
}
