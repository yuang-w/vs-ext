{
  "name": "copy-line-ref",
  "displayName": "Copy Line Reference",
  "description": "Copy file path with selected line range to clipboard as @file#Lstart-Lend",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyLineRef.copy",
        "title": "Copy Line Reference"
      }
    ],
    "keybindings": [
      {
        "command": "copyLineRef.copy",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus && editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
